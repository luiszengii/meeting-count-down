# macOS
.DS_Store

# Claude Code session-local state
.claude/

# Xcode
build/
DerivedData/
# 兜底忽略 Finder/Time Machine/Dropbox 等遇到 Spotlight 锁时自动生成的
# 带 " 2" / " 3" 数字后缀的 .xcodeproj 副本（xcodegen 只产出
# MeetingCountdown.xcodeproj，正版不带空格不带数字）。
# 出现过两次：2026-04-22 审计发现一次、2026-04-25 第二次。
MeetingCountdown\ [0-9]*.xcodeproj/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
*.xcuserstate
*.xcscmblueprint

# Swift Package Manager
.build/
.swiftpm/
# 顶级 Package.resolved（纯 SPM 工程用）忽略，
# 但 xcodegen 工程的解析文件在 xcodeproj 内部，需要入库以确保依赖版本可复现。
/Package.resolved
# 显式允许 xcodeproj 内部的 Package.resolved
!MeetingCountdown.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Archives and logs
*.ipa
*.dSYM.zip
*.dSYM
*.log

# App packaging
*.dmg
